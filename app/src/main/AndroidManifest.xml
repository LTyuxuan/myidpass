<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.police.pass">
    <application
        android:allowBackup="false"
        android:icon="@drawable/icon"
        android:label="电子通行证"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyIdPass"
        android:hardwareAccelerated="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
    <!-- 彻底移除所有网络权限，纯本地离线运行 -->
    <uses-permission android:name="android.permission.INTERNET" android:maxSdkVersion="0"/>
</manifest>
